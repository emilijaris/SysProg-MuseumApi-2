# Auto-detect text files and normalize to LF in repo
* text=auto

# --- Source code (keep LF in repo) ---
*.cs     text eol=lf
*.csproj text eol=lf
*.fs     text eol=lf
*.vb     text eol=lf
*.props  text eol=lf
*.targets text eol=lf
*.json   text eol=lf
*.xml    text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.md     text eol=lf
*.sh     text eol=lf
*.ps1    text eol=lf

# --- Visual Studio solution files (CRLF preferred) ---
*.sln text eol=crlf

# --- Git-related files ---
*.gitignore text eol=lf
*.gitattributes text eol=lf

# --- Windows scripts ---
*.cmd text eol=crlf
*.bat text eol=crlf

# --- Binary files (no conversion) ---
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz  binary
*.dll binary
*.exe binary
*.pdb binary

# --- Prevent diff noise for generated/minified files ---
*.min.js -text
*.min.css -text